APP_NAME=APEX Backend API
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1

# Supabase connection string (use the pooler URL with asyncpg).
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

JWT_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

ACCESS_COOKIE_NAME=apex_access_token
REFRESH_COOKIE_NAME=apex_refresh_token
CSRF_COOKIE_NAME=apex_csrf_token
SECURE_COOKIES=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
# En Render (produccion): SECURE_COOKIES=true y COOKIE_SAMESITE=none

# Frontend URLs allowed to call this API.
CORS_ORIGINS=http://localhost:3000,https://tu-frontend.onrender.com
TRUSTED_HOSTS=localhost,127.0.0.1,tu-api.onrender.com,tu-frontend.onrender.com

# Optional auto-bootstrap admin user.
DEFAULT_ADMIN_EMAIL=admin@apexntr.com
DEFAULT_ADMIN_PASSWORD=Cambia-Esta-Password-Ahora-123!

# Use true only for local quick setup.
AUTO_CREATE_TABLES=false

# Login brute-force guard
LOGIN_MAX_ATTEMPTS=6
LOGIN_WINDOW_SECONDS=60
